<?xml version="1.0"?>
<Container version="2">
  <Name>fb-reels-downloader</Name>
  <Repository>ghcr.io/fe4rL3ssC0der/fb-reels-downloader:latest</Repository> <!-- Change to your username -->
  <Registry>https://github.com/fe4rL3ssC0der/fb-reels-downloader</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/fe4rL3ssC0der/fb-reels-downloader/issues</Support>
  <Project>https://github.com/fe4rL3ssC0der/fb-reels-downloader</Project>
  <Overview>
    Beautiful dark-themed web GUI to download Facebook Reels from any public page. 
    Features: Multi-select, quality options, auto-monitoring, progress bars, mobile responsive, persistent settings.
  </Overview>
  <Description>
    Modern dashboard for downloading Facebook Reels. Built with FastAPI + HTMX + Tailwind. 
    yt-dlp powered. Perfect for Unraid.
  </Description>
  <Icon>https://raw.githubusercontent.com/fe4rL3ssC0der/fb-reels-downloader/main/icon.png</Icon> <!-- Optional: Add an icon later -->
  <Banner>https://raw.githubusercontent.com/fe4rL3ssC0der/fb-reels-downloader/main/banner.png</Banner> <!-- Optional -->
  
  <WebUI>http://[IP]:[PORT:8000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/fe4rL3ssC0der/fb-reels-downloader/main/fb-reels-downloader.xml</TemplateURL>
  
  <Category>Downloaders:Media</Category>
  <DateInstalled/>
  
  <!-- Ports -->
  <PortContainer>8000</PortContainer>
  <PortHost>8000</PortHost>
  <PortProtocol>tcp</PortProtocol>
  
  <!-- Volumes -->
  <Volume>
    <HostDir>/mnt/user/appdata/fb-reels-downloader</HostDir>
    <ContainerDir>/app</ContainerDir>
    <Mode>rw</Mode>
  </Volume>
  <Volume>
    <HostDir>/mnt/user/downloads/fb-reels</HostDir>
    <ContainerDir>/downloads</ContainerDir>
    <Mode>rw</Mode>
  </Volume>
  
  <!-- Environment Variables (optional) -->
  <ExtraParams>--build .</ExtraParams> <!-- Only if needed during first build -->
  
  <Config Name="Web Port" Target="8000" Default="8000" Mode="tcp" Description="Web UI Port" Required="true" Type="Port"/>
  
  <Config Name="Appdata Path" Target="/app" Default="/mnt/user/appdata/fb-reels-downloader" Mode="rw" Description="Config &amp; Settings" Required="true" Type="Path"/>
  <Config Name="Downloads Path" Target="/downloads" Default="/mnt/user/downloads/fb-reels" Mode="rw" Description="Where reels are saved" Required="true" Type="Path"/>
  
  <PostArg/>
</Container>
